{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "languageVersion": "2.0",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "1688952703119512191"
    }
  },
  "parameters": {
    "azureSubscriptionId": {
      "type": "string",
      "metadata": {
        "description": "Azure subscription ID for recipe resource provisioning"
      }
    },
    "azureResourceGroup": {
      "type": "string",
      "metadata": {
        "description": "Azure resource group for recipe-provisioned resources"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "westus3",
      "metadata": {
        "description": "Azure region for provisioned resources"
      }
    }
  },
  "imports": {
    "radius": {
      "provider": "radius",
      "version": "latest"
    },
    "radiusAi": {
      "provider": "radiusradiusai",
      "version": "0.0.1"
    },
    "radiusData": {
      "provider": "radiusradiusdata",
      "version": "0.0.1"
    },
    "radiusStorage": {
      "provider": "radiusradiusstorage",
      "version": "0.0.1"
    }
  },
  "resources": {
    "env": {
      "import": "radius",
      "type": "Applications.Core/environments@2023-10-01-preview",
      "properties": {
        "name": "azure",
        "location": "global",
        "properties": {
          "compute": {
            "kind": "kubernetes",
            "namespace": "azure"
          },
          "providers": {
            "azure": {
              "scope": "[format('/subscriptions/{0}/resourceGroups/{1}', parameters('azureSubscriptionId'), parameters('azureResourceGroup'))]"
            }
          },
          "recipes": {
            "Radius.AI/agents": {
              "default": {
                "templateKind": "bicep",
                "templatePath": "ghcr.io/reshrahim/recipes/agent:1.0",
                "parameters": {
                  "location": "[parameters('location')]"
                }
              }
            },
            "Radius.Data/postgreSqlDatabases": {
              "default": {
                "templateKind": "bicep",
                "templatePath": "ghcr.io/reshrahim/recipes/postgres:1.0",
                "parameters": {
                  "location": "[parameters('location')]"
                }
              }
            },
            "Radius.Storage/blobStorages": {
              "default": {
                "templateKind": "bicep",
                "templatePath": "ghcr.io/reshrahim/recipes/blobstorage:1.0",
                "parameters": {
                  "location": "[parameters('location')]"
                }
              }
            }
          }
        }
      }
    },
    "postgresql": {
      "import": "radiusData",
      "type": "Radius.Data/postgreSqlDatabases@2025-08-01-preview",
      "properties": {
        "name": "postgresql",
        "properties": {
          "environment": "[reference('env').id]",
          "size": "S"
        }
      },
      "dependsOn": [
        "env"
      ]
    },
    "blobstorage": {
      "import": "radiusStorage",
      "type": "Radius.Storage/blobStorages@2025-08-01-preview",
      "properties": {
        "name": "blobstorage",
        "properties": {
          "environment": "[reference('env').id]",
          "container": "documents"
        }
      },
      "dependsOn": [
        "env"
      ]
    }
  }
}